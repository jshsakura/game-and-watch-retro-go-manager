# Copy to .env and fill in. The .env is git-ignored — never commit real keys.

# IGDB (cover search). Optional: leave blank to disable the cover 검색기 — the app
# still works without it. Get free keys at https://api-docs.igdb.com/ (Twitch dev).
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=

# ── Docker-compose only (ignored by the local uvicorn dev run) ────────────────
# Host port to expose the app on (default 38472).
# GNW_HOST_PORT=38472
# Host path for persistent data (SQLite DB + uploaded ROMs/covers/media).
# Defaults to ./data next to docker-compose.yml; set an absolute path to relocate.
# GNW_DATA_PATH=/abs/path/to/gnw-data
# Container user id — match the host owner of GNW_DATA_PATH to avoid chown issues.
# UID=1001

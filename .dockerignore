# Node
frontend/node_modules
frontend/dist

# Python
**/__pycache__
**/*.pyc
**/*.pyo
**/*.pyd
.venv
venv

# Persistent data — ALL of it (DB, backups, recovery, uploads, name_map). The
# image must ship empty; the Dockerfile recreates the mount point. Never bake the
# local library/backups into a published image.
backend/data
data

# Secrets — never bake .env into the image (matches nested too, e.g. backend/.env)
**/.env
**/*.env
.env
.env.*

# Dev / editor artefacts
.git
.gitignore
*.md
*.log

# Test artefacts
.pytest_cache
htmlcov
.coverage
